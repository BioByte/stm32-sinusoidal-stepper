###############################################################################
# Project name (automatic from folder)
###############################################################################

PROJECT := $(notdir $(CURDIR))

BUILD   := build
OBJDIR  := $(BUILD)/obj
REPORT_DIR := $(BUILD)/reports

###############################################################################
# Detect CPU cores (for parallel build)
###############################################################################

ifeq ($(OS),Windows_NT)
CORES := $(NUMBER_OF_PROCESSORS)
else
CORES := $(shell nproc)
endif

###############################################################################
# Toolchain
###############################################################################

PREFIX  := arm-none-eabi-

CCACHE  := ccache

CC      := $(CCACHE) $(PREFIX)gcc
AS      := $(CCACHE) $(PREFIX)gcc
OBJCOPY := $(PREFIX)objcopy
SIZE    := $(PREFIX)size
OBJDUMP := $(PREFIX)objdump
NM      := $(PREFIX)nm

###############################################################################
# MCU configuration
###############################################################################

CPU     := cortex-m4
FPU     := fpv4-sp-d16
FLOAT   := hard

MCU := -mcpu=$(CPU) -mthumb -mfpu=$(FPU) -mfloat-abi=$(FLOAT)

###############################################################################
# Device selection
###############################################################################

DEFINES := \
-DSTM32F407xx

###############################################################################
# Linker script
###############################################################################

LDSCRIPT := linker/STM32F407XX_FLASH.ld

###############################################################################
# Optimization flags
###############################################################################

OPT := -O2

COMMON_FLAGS := $(MCU) \
$(OPT) \
-g3 \
-flto \
-ffunction-sections \
-fdata-sections \
-fno-common \
-Wall \
-Wextra \
$(DEFINES)

CFLAGS  := $(COMMON_FLAGS) -MMD -MP
ASFLAGS := $(MCU)

###############################################################################
# Linker flags
###############################################################################

LDFLAGS := $(MCU) \
-flto \
-T$(LDSCRIPT) \
-Wl,-Map=$(BUILD)/$(PROJECT).map \
-Wl,--gc-sections \
-Wl,--print-memory-usage \
--specs=nano.specs \
--specs=nosys.specs

###############################################################################
# Recursive wildcard
###############################################################################

rwildcard = \
$(foreach d,$(wildcard $1*),$(call rwildcard,$d/,$2)) \
$(filter $(subst *,%,$2),$(wildcard $1$2))

###############################################################################
# Source discovery
###############################################################################

SRC_DIR := .

C_SRC   := $(call rwildcard,$(SRC_DIR)/,*.c)
ASM_SRC := $(call rwildcard,$(SRC_DIR)/,*.s)
HDR_SRC := $(call rwildcard,$(SRC_DIR)/,*.h)

SRC := $(C_SRC) $(ASM_SRC)

###############################################################################
# Include directories
###############################################################################

INC_DIRS := $(sort $(dir $(C_SRC) $(HDR_SRC)))
INCLUDES := $(addprefix -I,$(INC_DIRS))

CFLAGS += $(INCLUDES)

###############################################################################
# Object mapping
###############################################################################

OBJ := $(patsubst %.c,$(OBJDIR)/%.o,$(C_SRC))
OBJ += $(patsubst %.s,$(OBJDIR)/%.o,$(ASM_SRC))

DEP := $(OBJ:.o=.d)

###############################################################################
# Output files
###############################################################################

ELF := $(BUILD)/$(PROJECT).elf
BIN := $(BUILD)/$(PROJECT).bin
HEX := $(BUILD)/$(PROJECT).hex
LST := $(BUILD)/$(PROJECT).lst
SYM := $(BUILD)/$(PROJECT).sym

###############################################################################
# Default target
###############################################################################

all: elf bin hex lst size

###############################################################################
# Parallel build
###############################################################################

MAKEFLAGS += -j$(CORES)

###############################################################################
# Compile C
###############################################################################

$(OBJDIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

###############################################################################
# Compile ASM
###############################################################################

$(OBJDIR)/%.o: %.s
	@mkdir -p $(dir $@)
	$(AS) $(ASFLAGS) -c $< -o $@

###############################################################################
# Link
###############################################################################

elf: $(ELF)

$(ELF): $(OBJ)
	@mkdir -p $(BUILD)
	$(CC) $(OBJ) $(LDFLAGS) -o $@

###############################################################################
# Binary
###############################################################################

bin: $(BIN)

$(BIN): $(ELF)
	$(OBJCOPY) -O binary $< $@

###############################################################################
# HEX
###############################################################################

hex: $(HEX)

$(HEX): $(ELF)
	$(OBJCOPY) -O ihex $< $@

###############################################################################
# Assembly listing
###############################################################################

lst: $(LST)

$(LST): $(ELF)
	$(OBJDUMP) -h -S $< > $@

###############################################################################
# Symbol table
###############################################################################

symbols: $(SYM)

$(SYM): $(ELF)
	@mkdir -p $(REPORT_DIR)
	$(NM) -n $< > $@

###############################################################################
# Size summary
###############################################################################

size:
	@echo ""
	@echo "========= SIZE SUMMARY ========="
	$(SIZE) --format=berkeley $(ELF)

###############################################################################
# MEMORY ANALYSIS
###############################################################################

sections:
	@echo ""
	@echo "========= MEMORY BY SECTION ========="
	$(SIZE) -A $(ELF)

memfunc:
	@echo ""
	@echo "========= MEMORY BY FUNCTION ========="
	$(NM) -S --size-sort --radix=d $(ELF) | grep " [tT] "

memram:
	@echo ""
	@echo "========= RAM VARIABLES ========="
	$(NM) -S --size-sort --radix=d $(ELF) | grep " [BD] "

top:
	@echo ""
	@echo "========= TOP 20 FUNCTIONS ========="
	$(NM) -S --size-sort --radix=d $(ELF) | grep " T " | tail -20

###############################################################################
# Flash firmware
###############################################################################

flash: $(ELF)
	JLink.exe -device STM32F407VE -if SWD -speed 4000 \
	-commanderscript flash.jlink

###############################################################################
# Debug server
###############################################################################

debug:
	JLinkGDBServerCL.exe -device STM32F407VE -if SWD -speed 4000 -port 2331

###############################################################################
# Clean
###############################################################################

clean:
	rm -rf $(BUILD)

###############################################################################
# Dependencies
###############################################################################

-include $(DEP)

###############################################################################
# Phony targets
###############################################################################

.PHONY: all elf bin hex lst clean flash debug size symbols \
memfunc memram top sections